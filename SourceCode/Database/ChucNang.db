USE ShiftPOS;

DELIMITER //

-- [FUNCTION 1] Tính số tiền tạm tính của một bàn cụ thể
CREATE FUNCTION fn_TinhTienBan(p_MaBan VARCHAR(10)) 
RETURNS INT DETERMINISTIC
BEGIN
    DECLARE Tong INT;
    SELECT SUM(CT.SoLuong * CT.DonGiaLucBan) INTO Tong
    FROM HOADON H JOIN CHITIET_HD CT ON H.MaHD = CT.MaHD
    WHERE H.MaBan = p_MaBan AND H.TrangThaiHD = 'Chưa thanh toán';
    RETURN IFNULL(Tong, 0);
END //

-- [FUNCTION 2] Tính tổng tiền CẦN THU 
CREATE FUNCTION fn_TongTienCanThu() 
RETURNS INT DETERMINISTIC
BEGIN
    DECLARE Tong INT;
    SELECT SUM(CT.SoLuong * CT.DonGiaLucBan) INTO Tong
    FROM HOADON H JOIN CHITIET_HD CT ON H.MaHD = CT.MaHD
    WHERE H.TrangThaiHD = 'Chưa thanh toán';
    RETURN IFNULL(Tong, 0);
END //

-- [FUNCTION 3] Tính tiền cho hóa đơn đã thanh toán
CREATE FUNCTION fn_TinhTienBan_ThanhToan(p_MaHD INT) 
RETURNS INT DETERMINISTIC
BEGIN
    DECLARE Tong INT;
    SELECT SUM(SoLuong * DonGiaLucBan) INTO Tong 
    FROM CHITIET_HD 
    WHERE MaHD = p_MaHD;
    RETURN IFNULL(Tong, 0);
END //

-- [PROCEDURE 1] Thêm khu vực mới
CREATE PROCEDURE sp_ThemKhuVuc(IN p_MaKV VARCHAR(10), IN p_TenKV VARCHAR(50))
BEGIN
    IF EXISTS (SELECT 1 FROM KHUVUC WHERE MaKV = p_MaKV) THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Lỗi: Mã khu vực này đã tồn tại!';
    ELSE
        INSERT INTO KHUVUC (MaKV, TenKV) VALUES (p_MaKV, p_TenKV);
    END IF;
END //

-- [PROCEDURE 2] Chuyển bàn
CREATE PROCEDURE sp_ChuyenBan(IN p_BanCu VARCHAR(10), IN p_BanMoi VARCHAR(10))
BEGIN
    UPDATE HOADON SET MaBan = p_BanMoi WHERE MaBan = p_BanCu AND TrangThaiHD = 'Chưa thanh toán';
    UPDATE BAN SET TrangThai = 'Đang phục vụ' WHERE MaBan = p_BanMoi;
    UPDATE BAN SET TrangThai = 'Trống' WHERE MaBan = p_BanCu;
END //

-- [PROCEDURE 3] Gộp bàn
CREATE PROCEDURE sp_GopBan(IN p_BanNguon VARCHAR(10), IN p_BanDich VARCHAR(10))
BEGIN
    UPDATE HOADON SET MaBan = p_BanDich WHERE MaBan = p_BanNguon AND TrangThaiHD = 'Chưa thanh toán';
    UPDATE BAN SET TrangThai = 'Trống' WHERE MaBan = p_BanNguon;
END //


-- [TRIGGER 1] Tự động dọn bàn khi thanh toán
-- 1. Thêm cột Phương thức thanh toán vào bảng Hóa đơn
ALTER TABLE HOADON ADD PhuongThucTT VARCHAR(50) DEFAULT 'Tiền mặt';
-- 2. Cập nhật lại Trigger Dọn Bàn 
-- Lúc trước, thanh toán 1 phát là bàn Trống luôn. Giờ 1 bàn có nhiều đơn, 
-- Trigger phải check: Khi nào tất cả các đơn trên bàn đó thanh toán hết thì bàn mới được Trống.
DELIMITER //
DROP TRIGGER IF EXISTS trg_DonBan_SauThanhToan //
CREATE TRIGGER trg_DonBan_SauThanhToan 
BEFORE UPDATE ON HOADON
FOR EACH ROW
BEGIN
    IF NEW.TrangThaiHD = 'Đã thanh toán' AND OLD.TrangThaiHD != 'Đã thanh toán' THEN
        SET NEW.ThoiGianDong = CURRENT_TIMESTAMP;
        -- Chỉ dọn bàn nếu bàn này không còn hóa đơn nào khác đang "Chưa thanh toán"
        IF (SELECT COUNT(*) FROM HOADON WHERE MaBan = NEW.MaBan AND TrangThaiHD = 'Chưa thanh toán' AND MaHD != NEW.MaHD) = 0 THEN
            UPDATE BAN SET TrangThai = 'Trống' WHERE MaBan = NEW.MaBan;
        END IF;
    END IF;
END //
DELIMITER ;

DELIMITER ;

-- [VIEW 1] Quản lý vị trí (Dashboard)
CREATE VIEW vw_QuanLyViTri AS
SELECT 
    B.MaBan, B.TenBan, K.TenKV, B.TrangThai, 
    H.MaHD, H.ThoiGianMo,
    fn_TinhTienBan(B.MaBan) AS TienTamTinh
FROM BAN B
JOIN KHUVUC K ON B.MaKV = K.MaKV
LEFT JOIN HOADON H ON B.MaBan = H.MaBan AND H.TrangThaiHD = 'Chưa thanh toán';

-- [VIEW 2] Báo cáo Doanh thu tổng hợp theo ngày
CREATE VIEW vw_DoanhThuTheoNgay AS
SELECT 
    DATE(ThoiGianDong) AS Ngay,
    COUNT(MaHD) AS SoHoaDon,
    SUM(fn_TinhTienBan_ThanhToan(MaHD)) AS TongDoanhThu
FROM HOADON
WHERE TrangThaiHD = 'Đã thanh toán'
GROUP BY DATE(ThoiGianDong);

-- [VIEW 3] Báo cáo Thu Chi 
CREATE VIEW vw_BaoCaoThuChi AS
SELECT 
    DATE(ThoiGian) AS Ngay,
    SUM(CASE WHEN LoaiPhieu = 'Thu' THEN SoTien ELSE 0 END) AS TongThuKhac,
    SUM(CASE WHEN LoaiPhieu = 'Chi' THEN SoTien ELSE 0 END) AS TongChi,
    (SUM(CASE WHEN LoaiPhieu = 'Thu' THEN SoTien ELSE 0 END) - SUM(CASE WHEN LoaiPhieu = 'Chi' THEN SoTien ELSE 0 END)) AS LoiNhuanRong
FROM THUCHI
GROUP BY DATE(ThoiGian);